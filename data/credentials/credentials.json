	},

	"google": {
		"api_key": "API_KEY"
	},

	"omekas":{
		"key_identity":"CLIENT_ID",
		"key_credential":"SECRET_KEY",
		"api_url": "http://{OMEKAS_URL}/api"
	},

	"wikidata": {
    "username": "{USERNAME}",
    "password": "{PASSWORD}",
    "consumer_token": "{TOKEN}",
    "consumer_secret": "{TOKEN_SECRET}",
