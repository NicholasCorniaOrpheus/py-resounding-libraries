{
	"koha": {
		"koha_api_url": "https://{KOHA_STAFF_URL}/api/v1",
		"koha_public_report_url": "https://{KOHA_OPAC_URL}/cgi-bin/koha/svc/report?id=",
		"koha_reports_url": "https://{KOHA_STAFF_URL}/cgi-bin/koha/svc/report?id=",
		"oauth_credentials": {
			"description": "{NAME}",
			"client_id": "{CLIENT_ID}",
			"client_secret": "{SECRET_KEY}",
			"user_agent": "{USER_AGENT/optional}"
			},
	
	},

	"transkribus": {
		"user": "{USER}",
		"password": "{PASSWORD}",
		"auth_url": "https://account.readcoop.eu/auth/realms/readcoop/protocol/openid-connect/token",
		"api_url": "https://transkribus.eu/processing/v1",
		"api_schema": "https://transkribus.eu/processing/v1/openapi.json"

	},

	"resourcespace": {
		"rs_api_url": "http://{RS_URL}/resourcespace/api/?",
		"secret_key": "{SECRET_KEY}",
		"username": "{USER}"
	},

	"orcid": {
		"client_id": "{CLIENT_ID",
		"client_secret": "{SECRET_KEY}",
		"redirect_uri": "https://{GITHUB_ORCiD_DOC_URI"
	},

	"zotero": {
		"client_id": "{CLIENT_ID}",
		"client_secret": "{SECRET_KEY}",
		"redirect_uri": "https://www.zotero.org/support/dev/web_api/v3/basics"
	},

	"google": {
		"api_key": "API_KEY"
	},

	"omekas":{
		"key_identity":"CLIENT_ID",
		"key_credential":"SECRET_KEY",
		"api_url": "http://{OMEKAS_URL}/api"
	},

	"wikidata": {
		"username": "{USERNAME}",
		"password": "{PASSWORD}"
	}

}